# Production server port.
PORT=8080

# Optional CORS origin for API-only mode. Same-origin deployment does not need this.
CORS_ORIGIN=https://your-domain.example

# Fuel price provider. The provider should return the FuelPriceSnapshot shape used by the app,
# or you can adapt server/api-server.mjs to normalize the provider response.
FUEL_PRICES_API_URL=
FUEL_PRICES_API_KEY=
FUEL_PRICES_API_KEY_HEADER=x-api-key
